class AgentCoordinator:
    def __init__(self, tickers):
        self.tickers = tickers
        self.agents = {
            'trend_follower': TrendFollowerAgent(),
            'mean_reversion': MeanReversionAgent(),
            'volatility': VolatilityAgent()
        }
        self.data_fetcher = DataFetcher()
        
    def run_cycle(self):
        decisions = {}
        for ticker in self.tickers:
            data = self.data_fetcher.fetch_data(ticker)
            agent_decisions = {}
            
            for name, agent in self.agents.items():
                agent_decisions[name] = agent.decide(data)
                
            # Meta-agent makes final decision
            decisions[ticker] = self._aggregate_decisions(agent_decisions)
        
        return decisions
    
